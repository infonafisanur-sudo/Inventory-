rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based Access Control helpers (RBAC)
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return isSignedIn() && hasUserDoc()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : 'user';
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() == 'admin';
    }

    function isStoreManager() {
      return isSignedIn() && (getUserRole() == 'store' || getUserRole() == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Entity validation blueprints

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && data.role is string && (data.role == 'admin' || data.role == 'store' || data.role == 'user');
    }

    function isValidItem(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.quantity is int && data.quantity >= 0;
    }

    function isValidRequest(data) {
      return data.user_id is string && data.user_id.size() <= 128
        && data.item_id is string && data.item_id.size() <= 128
        && data.status is string && (data.status == 'pending' || data.status == 'approved' || data.status == 'rejected');
    }

    function isValidAssignedItem(data) {
      return data.user_id is string && data.user_id.size() <= 128
        && data.item_id is string && data.item_id.size() <= 128;
    }

    function isValidComplaint(data) {
      return data.user_id is string && data.user_id.size() <= 128
        && data.item_id is string && data.item_id.size() <= 128
        && data.message is string && data.message.size() > 0 && data.message.size() <= 1000
        && data.status is string && (data.status == 'pending' || data.status == 'resolved');
    }

    // ----------------------------------------
    // COLLECTION RULES
    // ----------------------------------------

    // 1. Users Collection
    match /users/{userId} {
      allow read, write: if isSignedIn();
    }

    // 2. Items Collection
    match /items/{itemId} {
      allow read, write: if isSignedIn();
    }

    // 3. Requests Collection
    match /requests/{requestId} {
      allow read, write: if isSignedIn();
    }

    // 4. Assigned Items Collection
    match /assigned_items/{assignmentId} {
      allow read, write: if isSignedIn();
    }

    // 5. Complaints Collection
    match /complaints/{complaintId} {
      allow read, write: if isSignedIn();
    }
  }
}
